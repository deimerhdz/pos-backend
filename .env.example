# --- PostgreSQL (usados por docker-compose para el servicio 'postgres') ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=cambia-esto
POSTGRES_DB=pos_db

# --- Conexiones de la app ---
# En docker-compose el host es el nombre del servicio ('postgres' / 'redis'),
# no 'localhost'. Para desarrollo fuera de Docker usa localhost.
DATABASE_URL=postgresql+psycopg://admin:cambia-esto@postgres:5432/pos_db
REDIS_URL=redis://redis:6379/0

# --- Seguridad / JWT ---
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRY=1440
PROJECT_NAME=pos

# --- Email (Resend) ---
RESEND_API_KEY=
MAIL_FROM_NAME=Mi app
MAIL_FROM=onboarding@resend.dev

# --- Super admin sembrado en el primer arranque ---
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=admin@admin.com
SUPER_ADMIN_PASSWORD=Admin1234!
